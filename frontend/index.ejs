<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MODAMYM — Páginas</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="./css/tailwind-compiled.css">
</head>

<body class="font-dm bg-[#F4F6F8] text-[#101828] overflow-x-hidden">

    <!-- ══════════════════════════════════════
     LOGIN PAGE
══════════════════════════════════════ -->
    <div class="min-h-screen grid grid-cols-[0.9fr_1.1fr]">

        <!-- ── Painel Esquerdo ── -->
        <div class="login-blob-top login-blob-bottom
                relative overflow-hidden flex flex-col justify-between p-12
                bg-[linear-gradient(145deg,#0a0f1a_0%,#0d2818_100%)]">

            <!-- Logo -->
            <div class="relative z-10">
                <div class="font-playfair text-[26px] font-black text-white flex items-center gap-3 mb-14">
                    <span class="w-[10px] h-[10px] bg-[#00A63E] rounded-full inline-block"></span>
                    MODAMYM
                </div>
            </div>

            <!-- Hero Text -->
            <div class="relative z-10">
                <h2 class="font-playfair text-[48px] font-black text-white leading-[1.1] tracking-[-1.5px] mb-5">
                    Moda que <em class="text-[#4ade80] not-italic">inspira</em> propósito
                </h2>
                <p class="text-white/55 text-base leading-[1.7] max-w-[380px]">
                    Acesse sua conta e descubra peças sustentáveis com estilo e responsabilidade.
                    Mais de 500 produtos exclusivos.
                </p>
            </div>

            <!-- Stats -->
            <div class="relative z-10 flex gap-10">
                <div>
                    <div class="font-playfair text-[28px] font-bold text-white">500+</div>
                    <div class="text-xs text-white/40 mt-0.5">Produtos</div>
                </div>
                <div>
                    <div class="font-playfair text-[28px] font-bold text-white">12x</div>
                    <div class="text-xs text-white/40 mt-0.5">Sem juros</div>
                </div>
                <div>
                    <div class="font-playfair text-[28px] font-bold text-white">4.9★</div>
                    <div class="text-xs text-white/40 mt-0.5">Avaliação</div>
                </div>
            </div>
        </div>

        <!-- ── Painel Direito (Formulário) ── -->
        <div class="bg-white flex items-center justify-center p-12">
            <div class="w-full max-w-[420px]">

                <h1 class="font-playfair text-[32px] font-bold text-[#101828] mb-2">Bem-vindo de volta</h1>
                <p class="text-[#6A7282] text-[14.5px] leading-[1.6] mb-9">
                    Entre na sua conta para continuar comprando com segurança.
                </p>

                <!-- Social Login -->
                <div class="flex gap-3">
                    <!-- Google -->
                    <button class="flex-1 flex items-center justify-center gap-2
                               px-3 py-3 rounded-xl border-[1.5px] border-[#E5E7EB]
                               bg-white font-dm text-[13px] font-semibold text-[#101828]
                               transition-colors duration-200
                               hover:border-[#00A63E] hover:bg-[#e8f7ee]">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                            <path
                                d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                                fill="#4285F4" />
                            <path
                                d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                                fill="#34A853" />
                            <path
                                d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                                fill="#FBBC05" />
                            <path
                                d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                                fill="#EA4335" />
                        </svg>
                        Continuar com Google
                    </button>
                </div>

                <!-- Divider -->
                <div class="flex items-center gap-3 my-6">
                    <div class="flex-1 h-px bg-[#E5E7EB]"></div>
                    <span class="text-xs text-[#99A1AF] font-medium">ou entre com email</span>
                    <div class="flex-1 h-px bg-[#E5E7EB]"></div>
                </div>

                <!-- Email -->
                <div class="mb-5">
                    <label class="block text-[13px] font-semibold text-[#101828] mb-2">Email</label>
                    <input type="email" placeholder="seu@email.com" required class="w-full bg-[#F4F6F8] border-[1.5px] border-[#E5E7EB] rounded-xl
                           px-4 py-[13px] text-[14px] text-[#101828] outline-none font-dm
                           placeholder:text-[#99A1AF]
                           transition-colors duration-200
                           focus:border-[#00A63E] focus:bg-white">
                </div>

                <!-- Senha -->
                <div class="mb-5">
                    <label class="block text-[13px] font-semibold text-[#101828] mb-2">Senha</label>
                    <div class="relative">
                        <input type="password" id="password" placeholder="••••••••" class="w-full bg-[#F4F6F8] border-[1.5px] border-[#E5E7EB] rounded-xl
                               px-4 pr-12 py-[13px] text-[14px] text-[#101828] outline-none font-dm
                               placeholder:text-[#99A1AF]
                               transition-colors duration-200
                               focus:border-[#00A63E] focus:bg-white">
                        <button onclick="togglePasswordVisibility()" id="password-toggle"
                            class="absolute right-[14px] top-1/2 -translate-y-1/2 bg-transparent border-none cursor-pointer text-[#99A1AF] flex items-center">
                            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8"
                                viewBox="0 0 24 24">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- Remember me / Forgot -->
                <div class="flex justify-between items-center mb-7">
                    <a href="#" class="text-[13px] text-[#00A63E] font-semibold no-underline hover:underline">
                        Esqueceu a senha?
                    </a>
                </div>

                <!-- CTA -->
                <button class="w-full flex items-center justify-center gap-2.5
                           bg-[#00A63E] text-white border-none rounded-xl
                           px-7 py-[15px] text-[15px] font-semibold font-dm cursor-pointer
                           shadow-[0_4px_20px_rgba(0,166,62,0.3)]
                           transition-all duration-200
                           hover:bg-[#009136] hover:-translate-y-px hover:shadow-[0_6px_28px_rgba(0,166,62,0.4)]">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"
                        viewBox="0 0 24 24">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                        <polyline points="10 17 15 12 10 7" />
                        <line x1="15" x2="3" y1="12" y2="12" />
                    </svg>
                    Entrar na conta
                </button>

                <!-- Footer do form -->
                <div class="mt-8 text-center text-[13.5px] text-[#6A7282]">
                    Não tem conta?
                    <a href="/auth/cadastro.ejs" class="text-[#00A63E] font-semibold no-underline hover:underline">
                        Criar conta grátis →
                    </a>
                </div>

            </div>
        </div>
    </div>

    <!-- ══ Footer ══ -->
    <footer class="bg-[#101828] px-16 py-10">
        <div class="max-w-[1280px] mx-auto flex justify-between items-center text-[12.5px] text-white/50">
            <div class="font-playfair text-[18px] font-black text-white flex items-center gap-2">
                <span class="w-[7px] h-[7px] bg-[#00A63E] rounded-full inline-block"></span>
                MODAMYM
            </div>
            <span>© 2026 MODAMYM. Todos os direitos reservados.</span>
        </div>
    </footer>

    <script>
        function togglePasswordVisibility() {
            const passwordInput = document.getElementById('password');
            const passwordToggle = document.getElementById('password-toggle');
            const isHidden = passwordInput.type === 'password';

            passwordInput.type = isHidden ? 'text' : 'password';

            passwordToggle.innerHTML = isHidden
                ? /* olho fechado (senha oculta) */
                `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <line x1="2" y1="2" x2="22" y2="22"/>
                <path d="M6.71 6.71A10.9 10.9 0 0 0 2 12s4 8 10 8a10.7 10.7 0 0 0 5.29-1.71"/>
                <path d="M13.89 13.89A3 3 0 0 1 8.11 8.11"/>
                <path d="M17.5 17.5C19.5 15.8 22 12 22 12s-4-8-10-8c-1.4 0-2.74.25-4 .68"/>
            </svg>`
                : /* olho aberto (senha visível) */
                `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
            </svg>`;
        }
    </script>
</body>

</html>