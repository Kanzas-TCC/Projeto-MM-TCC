<!-- === INÍCIO DAS ALTERAÇÕES: SIDEBAR DESKTOP === -->
<!-- A classe 'hidden md:flex' oculta a sidebar vertical no mobile e exibe apenas em telas md ou maiores -->
<aside class="hidden md:flex w-64 bg-[#101828] h-screen fixed left-0 top-0 flex-col z-50">

    <!-- Logo -->
    <div class="px-6 pt-7 pb-6 border-b border-white/8 flex items-center gap-2.5">
        <div>
            <div class="font-playfair text-[16px] font-bold text-white">MODAMYM</div>
            <div class="text-[9px] text-white/35 font-medium tracking-[1px] uppercase">Admin</div>
        </div>
    </div>

    <!-- Nav -->
    <nav class="flex-1 px-3 py-4 overflow-y-auto">

        <!-- Geral -->
        <div class="mb-6">
            <div class="text-[10px] font-bold text-white/30 tracking-[1.2px] uppercase px-3 mb-1.5">Geral</div>

            <a href="/"
                class="<% if (currentPage === '/') { %>nav-item-active bg-[rgba(0,166,62,0.2)] text-[#4ade80]<% } else { %>text-white/75 hover:bg-white/[0.07] hover:text-white/90<% } %> relative flex items-center gap-2.75 px-3 py-2.25 rounded-[9px] cursor-pointer text-[13.5px] font-medium no-underline transition-all duration-150">
                <svg class="w-4.25 h-4.25 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                    viewBox="0 0 24 24">
                    <rect x="3" y="3" width="7" height="7" rx="1" />
                    <rect x="14" y="3" width="7" height="7" rx="1" />
                    <rect x="3" y="14" width="7" height="7" rx="1" />
                    <rect x="14" y="14" width="7" height="7" rx="1" />
                </svg>
                Dashboard
            </a>
        </div>

        <!-- Anúncios -->
        <div class="mb-6">
            <div class="text-[10px] font-bold text-white/30 tracking-[1.2px] uppercase px-3 mb-1.5">Anúncios</div>

            <a href="/ads"
                class="<% if (currentPage === '/ads') { %>nav-item-active bg-[rgba(0,166,62,0.2)] text-[#4ade80]<% } else { %>text-white/75 hover:bg-white/[0.07] hover:text-white/90<% } %> relative flex items-center gap-2.75 px-3 py-2.25 rounded-[9px] cursor-pointer text-[13.5px] font-medium no-underline transition-all duration-150">
                <svg class="w-4.25 h-4.25 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                    viewBox="0 0 24 24">
                    <path
                        d="M19 11H5m14 0a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-6a2 2 0 0 1 2-2m14 0V9a2 2 0 0 0-2-2M5 11V9a2 2 0 0 1 2-2m0 0V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2M7 7h10" />
                </svg>
                Gestão de Anúncios
            </a>

            <a href="/ads/create"
                class="<% if (currentPage === '/ads/create') { %>nav-item-active bg-[rgba(0,166,62,0.2)] text-[#4ade80]<% } else { %>text-white/75 hover:bg-white/[0.07] hover:text-white/90<% } %> relative flex items-center gap-2.75 px-3 py-2.25 rounded-[9px] cursor-pointer text-[13.5px] font-medium no-underline transition-all duration-150">
                <svg class="w-4.25 h-4.25 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                    viewBox="0 0 24 24">
                    <path d="M12 5v14m-7-7h14" />
                </svg>
                Criar Anúncios
            </a>

            <a href="/ads/edit"
                class="<% if (currentPage === '/ads/edit') { %>nav-item-active bg-[rgba(0,166,62,0.2)] text-[#4ade80]<% } else { %>text-white/75 hover:bg-white/[0.07] hover:text-white/90<% } %> relative flex items-center gap-2.75 px-3 py-2.25 rounded-[9px] cursor-pointer text-[13.5px] font-medium no-underline transition-all duration-150">
                <svg class="w-4.25 h-4.25 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                    viewBox="0 0 24 24">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                </svg>
                Editar Anúncios
            </a>
        </div>

        <!-- Produtos -->
        <div class="mb-6">
            <div class="text-[10px] font-bold text-white/30 tracking-[1.2px] uppercase px-3 mb-1.5">Produtos</div>

            <a href="/products"
                class="<% if (currentPage === '/products') { %>nav-item-active bg-[rgba(0,166,62,0.2)] text-[#4ade80]<% } else { %>text-white/75 hover:bg-white/[0.07] hover:text-white/90<% } %> relative flex items-center gap-2.75 px-3 py-2.25 rounded-[9px] cursor-pointer text-[13.5px] font-medium no-underline transition-all duration-150">
                <svg class="w-4.25 h-4.25 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                    viewBox="0 0 24 24">
                    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                    <line x1="3" x2="21" y1="6" y2="6" />
                    <path d="M16 10a4 4 0 0 1-8 0" />
                </svg>
                Produtos
            </a>

            <a href="/products/create"
                class="<% if (currentPage === '/products/create') { %>nav-item-active bg-[rgba(0,166,62,0.2)] text-[#4ade80]<% } else { %>text-white/75 hover:bg-white/[0.07] hover:text-white/90<% } %> relative flex items-center gap-2.75 px-3 py-2.25 rounded-[9px] cursor-pointer text-[13.5px] font-medium no-underline transition-all duration-150">
                <svg class="w-4.25 h-4.25 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                    viewBox="0 0 24 24">
                    <path d="M12 5v14m-7-7h14" />
                </svg>
                Criar Produtos
            </a>

            <a href="/products/edit"
                class="<% if (currentPage === '/products/edit') { %>nav-item-active bg-[rgba(0,166,62,0.2)] text-[#4ade80]<% } else { %>text-white/75 hover:bg-white/[0.07] hover:text-white/90<% } %> relative flex items-center gap-2.75 px-3 py-2.25 rounded-[9px] cursor-pointer text-[13.5px] font-medium no-underline transition-all duration-150">
                <svg class="w-4.25 h-4.25 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                    viewBox="0 0 24 24">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                </svg>
                Editar Produtos
            </a>
        </div>

        <!-- Finanças -->
        <div class="mb-6">
            <div class="text-[10px] font-bold text-white/30 tracking-[1.2px] uppercase px-3 mb-1.5">Finanças</div>

            <a href="/finances"
                class="<% if (currentPage === '/finances') { %>nav-item-active bg-[rgba(0,166,62,0.2)] text-[#4ade80]<% } else { %>text-white/75 hover:bg-white/[0.07] hover:text-white/90<% } %> relative flex items-center gap-2.75 px-3 py-2.25 rounded-[9px] cursor-pointer text-[13.5px] font-medium no-underline transition-all duration-150">
                <svg class="w-4.25 h-4.25 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                    viewBox="0 0 24 24">
                    <line x1="12" x2="12" y1="1" y2="23" />
                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                </svg>
                Faturamento e Lucros
            </a>
        </div>

        <!-- Sistema -->
        <div class="mb-6">
            <div class="text-[10px] font-bold text-white/30 tracking-[1.2px] uppercase px-3 mb-1.5">Sistema</div>

            <a href="/settings"
                class="<% if (currentPage === '/settings') { %>nav-item-active bg-[rgba(0,166,62,0.2)] text-[#4ade80]<% } else { %>text-white/75 hover:bg-white/[0.07] hover:text-white/90<% } %> relative flex items-center gap-2.75 px-3 py-2.25 rounded-[9px] cursor-pointer text-[13.5px] font-medium no-underline transition-all duration-150">
                <svg class="w-4.25 h-4.25 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                    viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="3" />
                    <path d="M19.07 4.93a10 10 0 0 1 1.414 14.143M4.93 4.93A10 10 0 0 0 3.515 19.07" />
                </svg>
                Configurações
            </a>
        </div>
    </nav>

    <!-- User -->
    <div class="px-3 py-4 border-t border-white/8">
        <div
            class="flex items-center gap-2.5 px-3 py-2.5 rounded-[10px] cursor-pointer transition-colors duration-150 hover:bg-white/[0.07]">
            <div
                class="w-8.5 h-8.5 rounded-full bg-[linear-gradient(135deg,#00A63E,#059669)] flex items-center justify-center text-white text-[13px] font-bold shrink-0">
                A</div>
            <div>
                <div class="text-[12.5px] font-semibold text-white">Admin</div>
                <div class="text-[11px] text-white/40">Administrador</div>
            </div>
        </div>
    </div>
</aside>
<!-- === FIM DAS ALTERAÇÕES: SIDEBAR DESKTOP === -->

<!-- === INÍCIO DAS ALTERAÇÕES: BOTTOMBAR MOBILE === -->
<!-- A classe 'md:hidden' garante que esta barra inferior apareça apenas no mobile, e os links secundários são ocultados como solicitado -->
<nav class="md:hidden fixed bottom-0 left-0 w-full z-50 flex flex-row justify-around items-center bg-white border-t border-slate-200 py-2 pb-safe shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)]">
    
    <!-- 1. Geral (Dashboard) -->
    <a href="/" class="flex flex-col items-center justify-center <% if (currentPage === '/') { %>text-emerald-700<% } else { %>text-slate-500 hover:text-slate-900<% } %> transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <rect x="3" y="3" width="7" height="7" rx="1" />
            <rect x="14" y="3" width="7" height="7" rx="1" />
            <rect x="3" y="14" width="7" height="7" rx="1" />
            <rect x="14" y="14" width="7" height="7" rx="1" />
        </svg>
        <span class="text-[10px] font-medium mt-1">Geral</span>
    </a>

    <!-- 2. Anúncios -->
    <a href="/ads" class="flex flex-col items-center justify-center <% if (currentPage === '/ads' || currentPage === '/ads/create' || currentPage === '/ads/edit') { %>text-emerald-700<% } else { %>text-slate-500 hover:text-slate-900<% } %> transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M19 11H5m14 0a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-6a2 2 0 0 1 2-2m14 0V9a2 2 0 0 0-2-2M5 11V9a2 2 0 0 1 2-2m0 0V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2M7 7h10" />
        </svg>
        <span class="text-[10px] font-medium mt-1">Anúncios</span>
    </a>

    <!-- 3. Produtos -->
    <a href="/products" class="flex flex-col items-center justify-center <% if (currentPage === '/products' || currentPage === '/products/create' || currentPage === '/products/edit') { %>text-emerald-700<% } else { %>text-slate-500 hover:text-slate-900<% } %> transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
            <line x1="3" x2="21" y1="6" y2="6" />
            <path d="M16 10a4 4 0 0 1-8 0" />
        </svg>
        <span class="text-[10px] font-medium mt-1">Produtos</span>
    </a>

    <!-- 4. Finanças -->
    <a href="/finances" class="flex flex-col items-center justify-center <% if (currentPage === '/finances') { %>text-emerald-700<% } else { %>text-slate-500 hover:text-slate-900<% } %> transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <line x1="12" x2="12" y1="1" y2="23" />
            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
        </svg>
        <span class="text-[10px] font-medium mt-1">Finanças</span>
    </a>

</nav>
<!-- === FIM DAS ALTERAÇÕES: BOTTOMBAR MOBILE === -->