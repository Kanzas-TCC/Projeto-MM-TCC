<header class="sticky top-0 z-40 h-16 w-full bg-white/80 backdrop-blur-md border-b border-slate-100 shadow-sm flex items-center justify-between px-4 md:px-6 lg:px-8 transition-all">
    
    <!-- LADO ESQUERDO: Identidade / Rota Atual -->
    <div class="flex items-center gap-3 shrink-0">
        
        <!-- Logo Compacta -->
        <div class="flex items-center gap-2.5">
            <div class="w-8 h-8 lg:w-9 lg:h-9 rounded-lg bg-slate-900 text-white flex items-center justify-center font-playfair font-bold text-sm lg:text-base shadow-sm shrink-0">
                M
            </div>
            <span class="text-[15px] lg:text-base font-bold text-slate-900 tracking-tight hidden sm:block truncate max-w-[100px] lg:max-w-full">Dashboard</span>
        </div>

        <!-- Separador sutil apenas desktop -->
        <div class="hidden md:block w-px h-5 bg-slate-200 mx-1 lg:mx-2"></div>

        <!-- Calendário/Data Widget (Transformado em ícone clicável no md, expande data no xl) -->
        <button class="hidden sm:flex items-center justify-center gap-1.5 bg-slate-50 border border-slate-200 rounded-lg p-2 xl:px-3 text-xs font-semibold text-slate-500 hover:bg-slate-100 transition-colors focus:outline-none">
            <svg class="w-4 h-4 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
            <span class="hidden xl:inline-block whitespace-nowrap"><%- day + " de " + month + " de " + year -%></span>
        </button>
    </div>

    <!-- CENTRO: Campo de Busca Adaptável -->
    <div class="hidden md:flex flex-1 justify-center px-4 max-w-sm lg:max-w-md">
        <div class="relative w-full transition-all">
            <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none w-4 h-4"
                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.35-4.35" />
            </svg>
            <!-- Placeholder reduzido para "Buscar..." p/ evitar over-squeezing no iPad -->
            <input type="text" placeholder="Buscar..." class="w-full bg-slate-50 border border-slate-200 rounded-full py-1.5 lg:py-2 pl-9 pr-4 text-xs lg:text-sm text-slate-900 outline-none font-dm transition-all focus:ring-2 focus:ring-slate-900/10 focus:border-slate-400 focus:bg-white placeholder-slate-400">
        </div>
    </div>

    <!-- LADO DIREITO: Ações Múltiplas e Perfil -->
    <!-- gap-x-2 de 768px a 1024px, gap-x-4 acima de 1280px (xl) -->
    <div class="flex items-center gap-x-2 xl:gap-x-4 shrink-0 transition-all">
        
        <!-- Botão Busca Mobile Apenas Ícone (visível apenas <768px) -->
        <button class="md:hidden p-2 text-slate-400 hover:text-slate-900 transition-colors focus:outline-none">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.35-4.35" />
            </svg>
        </button>

        <!-- Sino de Notificações com Badge -->
        <button class="relative p-2 text-slate-400 hover:text-slate-900 transition-colors focus:outline-none focus:ring-2 focus:ring-slate-100 rounded-full">
            <svg class="w-5 h-5 lg:w-[22px] lg:h-[22px]" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                <path d="M13.73 21a2 2 0 0 1-3.46 0" />
            </svg>
            <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
        </button>

        <!-- Divisor vertical Desktop -->
        <div class="w-px h-6 bg-slate-200 hidden lg:block mx-1"></div>

        <!-- User Profile Avatar -->
        <button class="flex items-center gap-2 hover:bg-slate-50 rounded-full p-1 transition-colors lg:pr-3 border border-transparent hover:border-slate-100 focus:outline-none focus:bg-slate-50">
            <!-- Usando a primeira letra para simular o avatar -->
            <div class="w-8 h-8 lg:w-9 lg:h-9 rounded-full bg-[linear-gradient(135deg,#101828,#334155)] flex items-center justify-center text-white text-xs font-bold border-2 border-slate-50 shrink-0 shadow-sm">
                A
            </div>
            
            <!-- Labels ocultos <1024px (hidden lg:flex), com truncate p/ nomes longos -->
            <div class="hidden lg:flex flex-col text-left max-w-[120px]">
                <span class="text-[12.5px] font-bold text-slate-900 leading-tight truncate">Admin Master</span>
                <span class="text-[10px] text-slate-500 font-medium tracking-wide truncate">Modamym Store</span>
            </div>
            
            <!-- Seta de Dropdown -->
            <svg class="hidden lg:block w-3 h-3 text-slate-400 ml-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
        </button>
        
    </div>
</header>