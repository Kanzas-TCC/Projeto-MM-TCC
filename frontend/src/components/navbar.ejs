<header class="sticky top-0 z-40 h-16 w-full bg-white/80 backdrop-blur-md border-b border-slate-100 shadow-sm flex items-center justify-between px-4 md:px-8 transition-all">
    
    <!-- Lado Esquerdo: Identidade / Rota Atual -->
    <div class="flex items-center gap-3 md:gap-4">
        
        <!-- Logo Compacta (Aparece forte no Mobile como âncora visual) -->
        <div class="flex items-center gap-2.5">
            <div class="w-8 h-8 md:w-9 md:h-9 rounded-lg bg-slate-900 text-white flex items-center justify-center font-playfair font-bold text-sm md:text-base shadow-sm">
                M
            </div>
            <!-- Pode ser dinâmico no futuro: Nome da Rota -->
            <span class="text-[15px] md:text-base font-bold text-slate-900 tracking-tight hidden sm:block">Dashboard</span>
        </div>

        <!-- Separador sutil apenas desktop -->
        <div class="hidden md:block w-px h-5 bg-slate-200"></div>

        <!-- Data do dia (Versão clean/minimalista escondida no celular muito pequeno) -->
        <span class="hidden sm:inline-flex items-center gap-1.5 bg-slate-50 border border-slate-200 rounded-md px-2.5 py-1 text-[11px] font-semibold text-slate-500">
            <svg class="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
            <%- day + " de " + month + " de " + year -%>
        </span>
    </div>

    <!-- Lado Direito: Ações Múltiplas -->
    <div class="flex items-center gap-1 sm:gap-2 md:gap-4">
        
        <!-- Busca: Oculta a barra de texto no celular e vira apenas um ícone; expansível no Desktop -->
        <div class="relative hidden md:block">
            <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none w-4 h-4"
                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.35-4.35" />
            </svg>
            <input type="text" placeholder="Buscar pedidos, clientes..." class="bg-slate-50 border border-slate-200 rounded-full py-1.5 pl-9 pr-4 text-[12px] text-slate-900 outline-none w-48 lg:w-64 font-dm transition-all focus:ring-2 focus:ring-slate-900/10 focus:border-slate-400 focus:bg-white placeholder-slate-400">
        </div>

        <!-- Botão Lupa (Apenas visível via Mobile) -->
        <button class="md:hidden p-2 text-slate-400 hover:text-slate-900 transition-colors focus:outline-none">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.35-4.35" />
            </svg>
        </button>

        <!-- Sino de Notificações com Badge -->
        <button class="relative p-2 text-slate-400 hover:text-slate-900 transition-colors focus:outline-none focus:ring-2 focus:ring-slate-100 rounded-full">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                <path d="M13.73 21a2 2 0 0 1-3.46 0" />
            </svg>
            <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
        </button>

        <!-- Divisor vertical Desktop -->
        <div class="w-px h-6 bg-slate-200 hidden md:block ml-1 mr-1"></div>

        <!-- User Profile Avatar (Compacto no Mobile) -->
        <button class="flex items-center gap-2.5 hover:bg-slate-50/80 rounded-full p-1 transition-colors pr-2 md:pr-4 border border-transparent hover:border-slate-100 focus:outline-none focus:bg-slate-50">
            <!-- Usando a primeira letra para simular o avatar ou imagem real -->
            <div class="w-8 h-8 md:w-9 md:h-9 rounded-full bg-[linear-gradient(135deg,#101828,#334155)] flex items-center justify-center text-white text-xs font-bold border-2 border-slate-50 shrink-0 shadow-sm">
                A
            </div>
            <!-- Labels ocultos no celular para poupar espaço precioso -->
            <div class="hidden md:flex flex-col text-left">
                <span class="text-[12.5px] font-bold text-slate-900 leading-tight">Admin Master</span>
                <span class="text-[10px] text-slate-500 font-medium tracking-wide">Modamym Store</span>
            </div>
            <!-- Seta de Dropdown -->
            <svg class="hidden md:block w-3.5 h-3.5 text-slate-400 ml-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
        </button>
        
    </div>
</header>