<script>
    function enableSidebar() {
        const window = document.querySelector('#window')
        window.classList.remove('hidden')
        window.classList.add('block')

        const mobileSidebar = document.querySelector('#mobileSidebar')
        mobileSidebar.classList.remove('-left-full')
        mobileSidebar.classList.add('left-0')
        
    }
    function disableSidebar() {
        const window = document.querySelector('#window')
        window.classList.remove('block')
        window.classList.add('hidden')
        
        const mobileSidebar = document.querySelector('#mobileSidebar')
        mobileSidebar.classList.remove('left-0')
        mobileSidebar.classList.add('-left-full')
        
    }
</script>

<header
    class="md:hidden sticky top-0 z-40 h-16 w-full bg-white/80 backdrop-blur-md border-b border-slate-100 shadow-sm flex items-center justify-end px-4 md:px-6 lg:px-8 transition-all">
    <div class="flex items-center gap-x-2 xl:gap-x-4 shrink-0 transition-all">
        <!-- Sino de Notificações com Badge -->
        <button
            class="relative p-2 text-slate-400 hover:text-slate-900 transition-colors focus:outline-none focus:ring-2 focus:ring-slate-100 rounded-full">
            <svg class="w-5 h-5 lg:w-[22px] lg:h-[22px]" fill="none" stroke="currentColor" stroke-width="2.2"
                viewBox="0 0 24 24">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                <path d="M13.73 21a2 2 0 0 1-3.46 0" />
            </svg>
            <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
        </button>

        <button id="btnToggleSidebar" onclick="enableSidebar()"
            class="relative p-2 text-slate-400 hover:text-slate-900 transition-colors focus:outline-none focus:ring-2 focus:ring-slate-100 rounded-full">
            <svg class="w-5 h-5 lg:w-[22px] lg:h-[22px]" fill="none" stroke="currentColor" stroke-width="2.2"
                viewBox="0 0 24 24">
                <path d="M4 7h16" />
                <path d="M4 12h16" />
                <path d="M4 17h16" />
            </svg>
        </button>
    </div>
</header>

<div id="window" onclick="disableSidebar()" class="w-full h-full bg-black opacity-15 hidden z-50 absolute left-0 right-0"></div>
