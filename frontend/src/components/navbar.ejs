<header
    class="md:hidden sticky top-0 z-40 h-16 w-full bg-white/80 backdrop-blur-md border-b border-slate-100 shadow-sm flex items-center justify-end px-4 md:px-6 lg:px-8 transition-all">
    <div class="flex items-center gap-x-2 xl:gap-x-4 shrink-0 transition-all">
        <!-- Sino de Notificações com Badge -->
        <button
            class="relative p-2 text-slate-400 hover:text-slate-900 transition-colors focus:outline-none focus:ring-2 focus:ring-slate-100 rounded-full">
            <svg class="w-5 h-5 lg:w-[22px] lg:h-[22px]" fill="none" stroke="currentColor" stroke-width="2.2"
                viewBox="0 0 24 24">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                <path d="M13.73 21a2 2 0 0 1-3.46 0" />
            </svg>
            <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
        </button>

        <button
            class="relative p-2 text-slate-400 hover:text-slate-900 transition-colors focus:outline-none focus:ring-2 focus:ring-slate-100 rounded-full">
            <svg class="w-5 h-5 lg:w-[22px] lg:h-[22px]" fill="none" stroke="currentColor" stroke-width="2.2"
                viewBox="0 0 24 24">
                <path d="M4 7h16" />
                <path d="M4 12h16" />
                <path d="M4 17h16" />
            </svg>
        </button>
    </div>
</header>


<aside
    class="fixed bottom-0 left-0 w-1/3 z-50 flex flex-col justify-around items-center bg-[#101828] border-t border-slate-800 py-2 h-full pb-safe shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.3)]">
    <div class="flex flex-col justify-evenly h-2/3">

        <!-- 1. Geral (Dashboard) -->
        <a href="/"
            class="bg-amber-50 flex items-center justify-between w-max-10 <% if (currentPage === '/') { %>text-emerald-500<% } else { %>text-slate-400 hover:text-white<% } %> transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <rect x="3" y="3" width="7" height="7" rx="1" />
                <rect x="14" y="3" width="7" height="7" rx="1" />
                <rect x="3" y="14" width="7" height="7" rx="1" />
                <rect x="14" y="14" width="7" height="7" rx="1" />
            </svg>
            <span class="text-md font-medium mt-1">Geral</span>
        </a>

        <!-- 2. Anúncios -->
        <a href="/ads"
            class="flex items-center justify-between w-max-10 <% if (currentPage === '/ads' || currentPage === '/ads/create' || currentPage === '/ads/edit') { %>text-emerald-500<% } else { %>text-slate-400 hover:text-white<% } %> transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path
                    d="M19 11H5m14 0a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-6a2 2 0 0 1 2-2m14 0V9a2 2 0 0 0-2-2M5 11V9a2 2 0 0 1 2-2m0 0V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2M7 7h10" />
            </svg>
            <span class="text-md font-medium mt-1">Anúncios</span>
        </a>

        <!-- 3. Produtos -->
        <a href="/products"
            class="flex items-center justify-between w-max-10 <% if (currentPage === '/products' || currentPage === '/products/create' || currentPage === '/products/edit') { %>text-emerald-500<% } else { %>text-slate-400 hover:text-white<% } %> transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                <line x1="3" x2="21" y1="6" y2="6" />
                <path d="M16 10a4 4 0 0 1-8 0" />
            </svg>
            <span class="text-md font-medium mt-1">Produtos</span>
        </a>

        <!-- 4. Finanças -->
        <a href="/finances"
            class="flex items-center justify-between w-max-10 <% if (currentPage === '/finances') { %>text-emerald-500<% } else { %>text-slate-400 hover:text-white<% } %> transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <line x1="12" x2="12" y1="1" y2="23" />
                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
            </svg>
            <span class="text-md font-medium mt-1">Finanças</span>
        </a>
    </div>

</aside>