<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MODAMYM — Gestão de Produtos</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="../../css/tailwind-compiled.css">
</head>

<body class="font-dm bg-slate-50 text-slate-900 flex min-h-screen">

    <%- include('../../components/sidebar.ejs') -%>

    <main class="md:ml-64 flex-1 flex flex-col min-h-screen transition-all duration-300 w-full overflow-hidden">

        <!-- Top Bar -->
        <%- include('../../components/navbar.ejs') -%>

            <!-- Content -->
            <div class="px-4 py-6 md:p-8 pb-24 md:pb-8 flex-1 w-full mx-auto max-w-7xl">

            <!-- Header -->
            <header class="mb-6 md:mb-8">
                <h1 class="text-2xl md:text-3xl font-bold text-slate-900">Gestão de Produtos</h1>
                <p class="text-sm md:text-base text-slate-500 mt-1">Gerencie seu catálogo centralizado de produtos e estoque.</p>
            </header>

            <!-- 2. Estratégia Mobile-First - Cards de KPI (grid-cols-1 md:grid-cols-4) -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
                <!-- Estética Limpa: bg-white com rounded-xl e border-slate-100 -->
                <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-4 shrink-0 hover:bg-slate-50 transition-colors">
                    <p class="text-xs text-slate-500 font-medium">Total de Itens</p>
                    <p class="text-xl md:text-2xl font-bold text-slate-900 mt-2">1.842</p>
                </div>
                <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-4 shrink-0 hover:bg-slate-50 transition-colors">
                    <p class="text-xs text-slate-500 font-medium">Produtos Sem Estoque</p>
                    <p class="text-xl md:text-2xl font-bold text-red-500 mt-2">14</p>
                </div>
                <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-4 shrink-0 hover:bg-slate-50 transition-colors">
                    <p class="text-xs text-slate-500 font-medium">Valor em Estoque</p>
                    <p class="text-xl md:text-2xl font-bold text-slate-900 mt-2">R$ 145K</p>
                </div>
                <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-4 shrink-0 hover:bg-slate-50 transition-colors">
                    <p class="text-xs text-slate-500 font-medium">Ativos no ML</p>
                    <p class="text-xl md:text-2xl font-bold text-slate-900 mt-2">91%</p>
                </div>
            </div>

            <!-- Filtros e Busca (w-full no mobile, gap-y-4 verticalmente empilhados) -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-4 mb-6">
                <div class="flex flex-col md:flex-row gap-y-4 gap-x-4 justify-between items-center">
                    
                    <!-- Busca (w-full) -->
                    <div class="relative w-full md:max-w-md">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                        </div>
                        <input type="text" placeholder="Buscar produto..."
                            class="block w-full pl-10 pr-3 py-2.5 border border-slate-200 rounded-lg bg-slate-50 text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-modamym-green/20 focus:border-modamym-green transition-all">
                    </div>

                    <!-- Filtros e Ação Rápida (w-full e empilhados no mobile) -->
                    <div class="flex flex-col md:flex-row w-full md:w-auto gap-y-4 gap-x-3 items-stretch md:items-center">
                        
                        <!-- Select w-full -->
                        <div class="relative w-full md:w-48">
                            <select class="appearance-none w-full pl-3 pr-10 py-2.5 border border-slate-200 rounded-lg bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-modamym-green/20 focus:border-modamym-green transition-all">
                                <option>Categorias</option>
                                <option>Calçados</option>
                                <option>Bolsas</option>
                            </select>
                            <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                                <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                </svg>
                            </div>
                        </div>

                        <!-- Botão Ação Rápida (w-full) -->
                        <button class="flex items-center justify-center gap-2 bg-slate-900 px-5 py-2.5 rounded-lg font-semibold text-sm text-white hover:bg-slate-800 transition-all shadow-sm w-full md:w-auto">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                            </svg>
                            Adicionar Produto
                        </button>
                        
                    </div>
                </div>
            </div>

            <!-- Tabela de Produtos Responsiva -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 w-full overflow-hidden">
                <!-- Wrapper que garante o scroll horizontal apenas na tabela limitando a estourar o layout -->
                <div class="overflow-x-auto w-full">
                    <table class="w-full text-left border-collapse min-w-[500px] md:min-w-0">
                        <thead class="bg-slate-50/50 border-b border-slate-100">
                            <tr>
                                <th class="px-4 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Produto</th>
                                <!-- Coluna SKU oculta no mobile (hidden md:table-cell) -->
                                <th class="px-4 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider hidden md:table-cell">SKU</th>
                                <!-- Coluna Categoria oculta no mobile -->
                                <th class="px-4 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider hidden lg:table-cell">Categoria</th>
                                <th class="px-4 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-right">Preço</th>
                                <th class="px-4 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-center">Estoque</th>
                                <th class="px-4 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-right">Ações</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">

                            <!-- Item 1 -->
                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="px-4 py-4">
                                    <div class="flex items-center gap-3">
                                        <!-- Thumbnail mantido, padding reduzido  -->
                                        <div class="h-10 w-10 rounded-lg bg-slate-100 flex-shrink-0 overflow-hidden border border-slate-100">
                                            <img src="https://www.figma.com/api/mcp/asset/87d18b6e-693f-47e4-9a06-ec827ae73103" alt="Produto" class="h-full w-full object-cover mix-blend-multiply">
                                        </div>
                                        <div class="min-w-0">
                                            <h3 class="text-[13px] md:text-sm font-semibold text-slate-900 truncate max-w-[120px] md:max-w-[200px]">Sapato Beira Rio Salto Baixo</h3>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-4 py-4 hidden md:table-cell">
                                    <span class="font-mono text-[12px] text-slate-500">SAP-BR-01</span>
                                </td>
                                <td class="px-4 py-4 hidden lg:table-cell">
                                    <span class="text-[12px] text-slate-500">Calçados</span>
                                </td>
                                <td class="px-4 py-4 text-right">
                                    <span class="text-[13px] md:text-sm font-bold text-slate-900">R$ 89,90</span>
                                </td>
                                <td class="px-4 py-4 text-center">
                                    <span class="text-[12px] md:text-xs font-medium text-emerald-600 bg-emerald-50 px-2 flex w-max mx-auto py-0.5 rounded-full">124 un.</span>
                                </td>
                                <td class="px-4 py-4 text-right">
                                    <button class="p-1.5 text-slate-400 hover:text-slate-900 hover:bg-slate-100 rounded-lg transition-all">
                                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
                                    </button>
                                </td>
                            </tr>

                            <!-- Item 2 -->
                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="px-4 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="h-10 w-10 rounded-lg bg-slate-100 flex-shrink-0 overflow-hidden border border-slate-100">
                                            <img src="https://www.figma.com/api/mcp/asset/1ebec4e8-c7af-4b70-96f0-6b10a474ad55" alt="Produto" class="h-full w-full object-cover mix-blend-multiply opacity-80">
                                        </div>
                                        <div class="min-w-0">
                                            <h3 class="text-[13px] md:text-sm font-semibold text-slate-900 truncate max-w-[120px] md:max-w-[200px]">Parka Premium</h3>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-4 py-4 hidden md:table-cell">
                                    <span class="font-mono text-[12px] text-slate-500">PK-FEM-L</span>
                                </td>
                                <td class="px-4 py-4 hidden lg:table-cell">
                                    <span class="text-[12px] text-slate-500">Promo</span>
                                </td>
                                <td class="px-4 py-4 text-right">
                                    <span class="text-[13px] md:text-sm font-bold text-slate-900">R$ 185,00</span>
                                </td>
                                <td class="px-4 py-4 text-center">
                                    <span class="text-[12px] md:text-xs font-medium text-red-600 bg-red-50 px-2 flex w-max mx-auto py-0.5 rounded-full">0 un.</span>
                                </td>
                                <td class="px-4 py-4 text-right">
                                    <button class="p-1.5 text-slate-400 hover:text-slate-900 hover:bg-slate-100 rounded-lg transition-all">
                                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
                                    </button>
                                </td>
                            </tr>

                        </tbody>
                    </table>
                </div>
                
                <!-- Footer Tabela -->
                <div class="px-4 md:px-6 py-4 border-t border-slate-100 flex items-center justify-between text-sm bg-slate-50/50">
                    <span class="text-slate-500 hidden sm:block">Mostrando <span class="font-bold text-slate-900">2</span> de <span class="font-bold text-slate-900">1.842</span></span>
                    <div class="flex items-center gap-2 w-full sm:w-auto justify-between sm:justify-end">
                        <button class="px-3 py-1.5 border border-slate-200 text-slate-400 bg-slate-50 rounded-lg">Anterior</button>
                        <span class="text-xs font-bold sm:hidden">Pág 1/92</span>
                        <button class="px-3 py-1.5 border border-slate-200 text-slate-600 bg-white rounded-lg shadow-sm">Próxima</button>
                    </div>
                </div>

            </div>
        </div>
    </main>
</body>
</html>
