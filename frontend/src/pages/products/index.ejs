<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MODAMYM — Gestão de Produtos</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="../../css/tailwind-compiled.css">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        dm: ['"DM Sans"', 'sans-serif'],
                        playfair: ['"Playfair Display"', 'serif'],
                    },
                    colors: {
                        modamym: {
                            green: '#00A63E',
                            'green-dark': '#009136',
                            navy: '#0a0f1a',
                            'navy-light': '#1e293b',
                            slate: {
                                50: '#F4F6F8',
                                900: '#101828',
                                500: '#6A7282',
                                100: '#E5E7EB',
                            }
                        }
                    }
                }
            }
        }
    </script>
</head>

<body class="font-dm bg-slate-50 text-modamym-slate-900 min-h-screen">

    <%- include('../../components/sidebar.ejs') -%>

    <!-- Container otimizado para mobile com padding inferior p/ Bottombar e horizontal reduzido (px-4) -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 pb-24 md:pb-8">

        <!-- Header -->
        <header class="mb-6 md:mb-8">
            <h1 class="text-2xl md:text-3xl font-bold text-slate-900">Gestão de Produtos</h1>
            <p class="text-sm md:text-base text-slate-500 mt-1">Gerencie seu catálogo centralizado de produtos e estoque.</p>
        </header>

        <!-- 1. Grid de Resumo de Estoque (Mobile-First: 2 colunas no mobile) -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 mb-6">
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-4 flex flex-col justify-between">
                <p class="text-xs text-slate-500 font-medium">Total de Itens</p>
                <p class="text-xl md:text-2xl font-bold text-slate-900 mt-2">1.842</p>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-4 flex flex-col justify-between">
                <p class="text-xs text-slate-500 font-medium">Sem Estoque</p>
                <p class="text-xl md:text-2xl font-bold text-red-500 mt-2">14</p>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-4 flex flex-col justify-between">
                <p class="text-xs text-slate-500 font-medium whitespace-nowrap overflow-hidden text-ellipsis">Valor em Estoque</p>
                <p class="text-xl md:text-2xl font-bold text-slate-900 mt-2">R$ 145K</p>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-4 flex flex-col justify-between">
                <p class="text-xs text-slate-500 font-medium">Categorias</p>
                <p class="text-xl md:text-2xl font-bold text-slate-900 mt-2">24</p>
            </div>
        </div>

        <!-- 3. Filtros e Busca (Ocupando w-full no mobile e empilhados verticalmente com gap-y-3) -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-3 md:p-4 mb-6">
            <div class="flex flex-col md:flex-row gap-y-3 gap-x-4 justify-between items-center">
                
                <!-- Busca (w-full no mobile) -->
                <div class="relative w-full md:max-w-md">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </div>
                    <input type="text" placeholder="Buscar por produto, SKU..."
                        class="block w-full pl-10 pr-3 py-2.5 border border-slate-200 rounded-lg bg-slate-50 text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-modamym-green/20 focus:border-modamym-green transition-all">
                </div>

                <!-- Filtros e Botão (w-full no mobile, flex-row no desktop) -->
                <div class="flex flex-col md:flex-row w-full md:w-auto gap-y-3 gap-x-3 items-stretch md:items-center">
                    
                    <div class="relative w-full md:w-48">
                        <select class="appearance-none w-full pl-3 pr-10 py-2.5 border border-slate-200 rounded-lg bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-modamym-green/20 focus:border-modamym-green transition-all">
                            <option>Todas as Categorias</option>
                            <option>Calçados</option>
                            <option>Vestuário</option>
                            <option>Acessórios</option>
                        </select>
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                            </svg>
                        </div>
                    </div>

                    <!-- 4. Botões de Ação Rápida (w-full no mobile) -->
                    <button class="flex items-center justify-center gap-2 bg-slate-900 px-5 py-2.5 rounded-lg font-semibold text-sm text-white hover:bg-slate-800 transition-all shadow-sm w-full md:w-auto">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                        Adicionar Produto
                    </button>
                    
                </div>
            </div>
        </div>

        <!-- 2. Transformação da Tabela (Desktop Table / Mobile Card View) -->
        <div class="bg-white rounded-xl shadow-sm shadow-inner border border-slate-100 overflow-x-auto w-full">
            <table class="w-full text-left border-collapse">
                
                <!-- Cabeçalho visível apenas no desktop -->
                <thead class="hidden md:table-header-group bg-slate-50/50 border-b border-slate-100">
                    <tr>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Produto</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">SKU</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-right">Preço</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-center">Estoque</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-right">Ações</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">

                    <!-- ================= ITEM 1 ================= -->
                    <!-- Desktop Row -->
                    <tr class="hidden md:table-row hover:bg-slate-50/50 transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-4">
                                <div class="h-12 w-12 rounded-lg bg-slate-100 flex-shrink-0 overflow-hidden border border-slate-100">
                                    <img src="https://www.figma.com/api/mcp/asset/87d18b6e-693f-47e4-9a06-ec827ae73103" alt="Produto" class="h-full w-full object-cover mix-blend-multiply">
                                </div>
                                <div>
                                    <h3 class="text-sm font-semibold text-slate-900">Sapato Beira Rio Salto Baixo</h3>
                                    <p class="text-[11px] text-slate-400 mt-0.5">Calçados</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="font-mono text-[12px] text-slate-500 bg-slate-50 px-2 py-1 rounded">SAP-BR-01</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <span class="text-sm font-bold text-slate-900">R$ 89,90</span>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <span class="text-sm font-medium text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-full">124 un.</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <button class="p-1.5 text-slate-400 hover:text-slate-900 hover:bg-slate-100 rounded-lg transition-all">
                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
                            </button>
                        </td>
                    </tr>
                    <!-- Mobile Card View -->
                    <tr class="md:hidden block p-4 hover:bg-slate-50 transition-colors border-b border-slate-100 last:border-0">
                        <td class="block w-full">
                            <div class="flex items-center gap-3 w-full">
                                <div class="h-14 w-14 rounded-lg bg-slate-100 shrink-0 overflow-hidden border border-slate-100">
                                    <img src="https://www.figma.com/api/mcp/asset/87d18b6e-693f-47e4-9a06-ec827ae73103" alt="Produto" class="h-full w-full object-cover mix-blend-multiply">
                                </div>
                                <div class="flex-1 min-w-0">
                                    <h3 class="text-[13px] font-bold text-slate-900 truncate">Sapato Beira Rio Salto Baixo</h3>
                                    <p class="text-[11px] text-slate-500 font-mono mt-0.5 tracking-tight">SAP-BR-01</p>
                                </div>
                                <div class="text-right shrink-0 flex flex-col items-end">
                                    <p class="text-sm font-bold text-slate-900">R$ 89,90</p>
                                    <p class="text-[10px] font-bold text-emerald-600 bg-emerald-50 px-1.5 py-0.5 rounded mt-1">124 un.</p>
                                </div>
                            </div>
                            <div class="mt-3 pt-3 border-t border-slate-100 flex justify-end">
                                <button class="text-[11px] font-bold text-slate-600 bg-slate-50 px-4 py-1.5 rounded-lg border border-slate-200">Editar Detalhes</button>
                            </div>
                        </td>
                    </tr>

                    <!-- ================= ITEM 2 ================= -->
                    <!-- Desktop Row -->
                    <tr class="hidden md:table-row hover:bg-slate-50/50 transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-4">
                                <div class="h-12 w-12 rounded-lg bg-slate-100 flex-shrink-0 overflow-hidden border border-slate-100">
                                    <img src="https://www.figma.com/api/mcp/asset/1ebec4e8-c7af-4b70-96f0-6b10a474ad55" alt="Produto" class="h-full w-full object-cover mix-blend-multiply">
                                </div>
                                <div>
                                    <h3 class="text-sm font-semibold text-slate-900">Parka Feminina Consciência</h3>
                                    <p class="text-[11px] text-slate-400 mt-0.5">Vestuário</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="font-mono text-[12px] text-slate-500 bg-slate-50 px-2 py-1 rounded">PK-FEM-L</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <span class="text-sm font-bold text-slate-900">R$ 185,00</span>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <span class="text-sm font-medium text-red-600 bg-red-50 px-2 py-0.5 rounded-full">0 un.</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <button class="p-1.5 text-slate-400 hover:text-slate-900 hover:bg-slate-100 rounded-lg transition-all">
                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
                            </button>
                        </td>
                    </tr>
                    <!-- Mobile Card View -->
                    <tr class="md:hidden block p-4 hover:bg-slate-50 transition-colors border-b border-slate-100 last:border-0 bg-red-50/20">
                        <td class="block w-full">
                            <div class="flex items-center gap-3 w-full">
                                <div class="h-14 w-14 rounded-lg bg-slate-100 shrink-0 overflow-hidden border border-slate-100">
                                    <img src="https://www.figma.com/api/mcp/asset/1ebec4e8-c7af-4b70-96f0-6b10a474ad55" alt="Produto" class="h-full w-full object-cover mix-blend-multiply opacity-80">
                                </div>
                                <div class="flex-1 min-w-0">
                                    <h3 class="text-[13px] font-bold text-slate-900 truncate">Parka Feminina Consciência</h3>
                                    <p class="text-[11px] text-slate-500 font-mono mt-0.5 tracking-tight">PK-FEM-L</p>
                                </div>
                                <div class="text-right shrink-0 flex flex-col items-end">
                                    <p class="text-sm font-bold text-slate-900">R$ 185,00</p>
                                    <p class="text-[10px] font-bold text-red-600 bg-red-100 px-1.5 py-0.5 rounded mt-1">Esgotado</p>
                                </div>
                            </div>
                            <div class="mt-3 pt-3 border-t border-slate-100 flex justify-end">
                                <button class="text-[11px] font-bold text-slate-600 bg-slate-50 px-4 py-1.5 rounded-lg border border-slate-200">Editar Detalhes</button>
                            </div>
                        </td>
                    </tr>

                </tbody>
            </table>
            
            <!-- Footer da Tabela -->
            <div class="px-4 md:px-6 py-4 border-t border-slate-100 flex items-center justify-between text-sm bg-slate-50/50">
                <span class="text-slate-500 hidden sm:block">Mostrando <span class="font-bold text-slate-900">2</span> de <span class="font-bold text-slate-900">1.842</span></span>
                <!-- Paginação Mobile simplificada -->
                <div class="flex items-center gap-2 w-full sm:w-auto justify-between sm:justify-end">
                    <button class="px-3 py-1.5 border border-slate-200 text-slate-400 bg-slate-50 rounded-lg">Anterior</button>
                    <span class="text-xs font-bold sm:hidden">Pág. 1/92</span>
                    <button class="px-3 py-1.5 border border-slate-200 text-slate-600 bg-white rounded-lg shadow-sm">Próxima</button>
                </div>
            </div>
            
        </div>
    </div>
</body>
</html>
