<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MODAMYM — Cadastro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="../../css/tailwind-compiled.css">
</head>

<body class="font-dm bg-[#F4F6F8] text-[#101828] overflow-x-hidden">

    <!-- ══════════════════════════════════════
     LOGIN PAGE
══════════════════════════════════════ -->
    <div class="min-h-screen grid grid-cols-1 lg:grid-cols-[0.9fr_1.1fr]">

        <!-- ── Painel Esquerdo ── -->
        <div class="login-blob-top login-blob-bottom
                relative overflow-hidden flex flex-col justify-between p-8 md:p-12
                bg-[linear-gradient(145deg,#0a0f1a_0%,#0d2818_100%)]">

            <!-- Logo -->
            <div class="relative z-10">
                <div class="font-playfair text-[24px] md:text-[26px] font-black text-white flex items-center gap-3 mb-10 md:mb-14">
                    <span class="w-2.5 h-2.5 bg-[#00A63E] rounded-full inline-block"></span>
                    MODAMYM
                </div>
            </div>

            <!-- Hero Text -->
            <div class="relative z-10 mb-12 lg:mb-0">
                <h2 class="font-playfair text-[32px] md:text-[48px] font-black text-white leading-[1.1] tracking-[-1.5px] mb-5">
                    Moda que <em class="text-[#4ade80] not-italic">inspira</em> propósito
                </h2>
                <p class="text-white/55 text-sm md:text-base leading-[1.7] max-w-95">
                    Acesse sua conta e descubra peças sustentáveis com estilo e responsabilidade.
                    Mais de 500 produtos exclusivos.
                </p>
            </div>

            <!-- Stats -->
            <div class="relative z-10 flex flex-wrap gap-6 md:gap-10">
                <div>
                    <div class="font-playfair text-[24px] md:text-[28px] font-bold text-white">500+</div>
                    <div class="text-xs text-white/40 mt-0.5">Produtos</div>
                 </div>
                <div>
                    <div class="font-playfair text-[24px] md:text-[28px] font-bold text-white">12x</div>
                    <div class="text-xs text-white/40 mt-0.5">Sem juros</div>
                </div>
                <div>
                    <div class="font-playfair text-[24px] md:text-[28px] font-bold text-white">4.9★</div>
                    <div class="text-xs text-white/40 mt-0.5">Avaliação</div>
                </div>
            </div>
        </div>

        <!-- ── Painel Direito (Formulário) ── -->
        <div class="bg-white flex items-center justify-center p-8 md:p-12">
            <div class="w-full max-w-105">

                <h1 class="font-playfair text-[28px] md:text-[32px] font-bold text-[#101828] mb-2">Bem-vindo(a)</h1>
                <p class="text-[#6A7282] text-[14.5px] leading-[1.6] mb-9">
                    Crie sua conta para administrar seu negócio.
                </p>

                <!-- Divider -->
                <div class="flex items-center gap-3 my-6">
                    <div class="flex-1 h-px bg-[#E5E7EB]"></div>
                    <div class="flex-1 h-px bg-[#E5E7EB]"></div>
                </div>

                <!-- Email -->
                <div class="mb-5">
                    <label for="email" class="block text-[13px] font-semibold text-[#101828] mb-2">Email</label>
                    <input type="email" id="email" placeholder="seu@email.com" required class="w-full bg-[#F4F6F8] border-[1.5px] border-[#E5E7EB] rounded-xl
                           px-4 py-3.25 text-[14px] text-[#101828] outline-none font-dm
                           placeholder:text-[#99A1AF]
                           transition-colors duration-200
                           focus:border-[#00A63E] focus:bg-white">
                </div>

                <!-- Senha -->
                <div class="mb-5">
                    <label for="password" class="block text-[13px] font-semibold text-[#101828] mb-2">Senha</label>
                    <div class="relative">
                        <input type="password" id="password" placeholder="••••••••" class="w-full bg-[#F4F6F8] border-[1.5px] border-[#E5E7EB] rounded-xl
                               px-4 pr-12 py-3.25 text-[14px] text-[#101828] outline-none font-dm
                               placeholder:text-[#99A1AF]
                               transition-colors duration-200
                               focus:border-[#00A63E] focus:bg-white">
                        <button onclick="togglePasswordVisibility()" id="password-toggle"
                            class="absolute right-3.5 top-1/2 -translate-y-1/2 bg-transparent border-none cursor-pointer text-[#99A1AF] flex items-center">
                            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8"
                                viewBox="0 0 24 24">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- Remember me / Forgot -->
                <div class="flex justify-between items-center mb-7">
                    <a href="./forgot-password.ejs" class="text-[13px] text-[#00A63E] font-semibold no-underline hover:underline">
                        Esqueceu a senha?
                    </a>
                </div>

                <!-- CTA -->
                <button class="w-full flex items-center justify-center gap-2.5
                           bg-[#00A63E] text-white border-none rounded-xl
                           px-7 py-3.75 text-[15px] font-semibold font-dm cursor-pointer
                           shadow-[0_4px_20px_rgba(0,166,62,0.3)]
                           transition-all duration-200
                           hover:bg-[#009136] hover:-translate-y-px hover:shadow-[0_6px_28px_rgba(0,166,62,0.4)]">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"
                        viewBox="0 0 24 24">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                        <polyline points="10 17 15 12 10 7" />
                        <line x1="15" x2="3" y1="12" y2="12" />
                    </svg>
                    Entrar na conta
                </button>

                <!-- Footer do form -->
                <div class="mt-8 text-center text-[13.5px] text-[#6A7282]">
                    Não tem conta?
                    <a href="sign-up.ejs" class="text-[#00A63E] font-semibold no-underline hover:underline">
                        Criar conta grátis →
                    </a>
                </div>

            </div>
        </div>
    </div>

    <%- include('../../components/footer.ejs') -%>

    <script>
        function togglePasswordVisibility() {
            const passwordInput = document.getElementById('password');
            const passwordToggle = document.getElementById('password-toggle');
            const isHidden = passwordInput.type === 'password';

            passwordInput.type = isHidden ? 'text' : 'password';

            passwordToggle.innerHTML = isHidden
                ? /* olho fechado (senha oculta) */
                `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <line x1="2" y1="2" x2="22" y2="22"/>
                <path d="M6.71 6.71A10.9 10.9 0 0 0 2 12s4 8 10 8a10.7 10.7 0 0 0 5.29-1.71"/>
                <path d="M13.89 13.89A3 3 0 0 1 8.11 8.11"/>
                <path d="M17.5 17.5C19.5 15.8 22 12 22 12s-4-8-10-8c-1.4 0-2.74.25-4 .68"/>
            </svg>`
                : /* olho aberto (senha visível) */
                `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
            </svg>`;
        }
    </script>
</body>

</html>