<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Faturamento e Lucro - Mercado Livre</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 antialiased p-4 md:p-6 lg:p-8">

    <div class="max-w-7xl mx-auto space-y-6">

        <!-- Header e Controles de Período -->
        <header class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6">
            <div>
                <h1 class="text-2xl md:text-3xl font-bold text-slate-900">Faturamento e Lucro</h1>
                <p class="text-slate-500 text-sm mt-1">Acompanhe o desempenho financeiro da sua loja no Mercado Livre</p>
            </div>
            
            <div class="flex flex-col md:flex-row flex-wrap items-start md:items-center gap-3 w-full lg:w-auto">
                <!-- Seletor Rápido -->
                <div class="inline-flex bg-white rounded-xl shadow-sm border border-slate-200 p-1">
                    <button class="px-3.5 py-2 text-sm font-medium rounded-lg text-slate-600 hover:text-slate-900 hover:bg-slate-50 transition-colors">Hoje</button>
                    <button class="px-3.5 py-2 text-sm font-medium rounded-lg text-slate-600 hover:text-slate-900 hover:bg-slate-50 transition-colors">Esta semana</button>
                    <button class="px-3.5 py-2 text-sm font-medium rounded-lg bg-emerald-800 text-white shadow-sm transition-colors">Este mês</button>
                    <button class="px-3.5 py-2 text-sm font-medium rounded-lg text-slate-600 hover:text-slate-900 hover:bg-slate-50 transition-colors">Este ano</button>
                </div>
                
                <!-- Data Customizada -->
                <div class="flex items-center bg-white rounded-xl shadow-sm border border-slate-200 p-1 pl-3">
                    <input type="date" value="2023-11-01" class="text-sm text-slate-600 focus:outline-none bg-transparent font-medium cursor-pointer">
                    <span class="text-slate-400 text-sm mx-2">até</span>
                    <input type="date" value="2023-11-30" class="text-sm text-slate-600 focus:outline-none bg-transparent font-medium cursor-pointer">
                    <button class="ml-2 px-4 py-2 text-sm font-medium bg-slate-900 text-white rounded-lg hover:bg-slate-800 transition-colors">Aplicar</button>
                </div>
                
                <!-- Exportar CSV -->
                <button class="flex items-center gap-2 px-4 py-2.5 text-sm font-medium bg-white border border-slate-200 text-slate-700 rounded-xl shadow-sm hover:bg-slate-50 transition-colors whitespace-nowrap ml-auto md:ml-0">
                    <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                    </svg>
                    Exportar CSV
                </button>
            </div>
        </header>

        <!-- Cards de Resumo de KPIs -->
        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4">
            <!-- KPI 1 -->
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 flex flex-col justify-between hover:shadow-md transition-shadow">
                <div class="flex justify-between items-start mb-4">
                    <h3 class="text-slate-500 text-sm font-medium">Receita Bruta Total</h3>
                    <div class="p-2.5 border border-slate-100 rounded-xl bg-slate-50 text-slate-400">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                </div>
                <div>
                    <p class="text-2xl font-bold text-slate-900">R$ 45.230,00</p>
                </div>
            </div>

            <!-- KPI 2 -->
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 flex flex-col justify-between hover:shadow-md transition-shadow">
                <div class="flex justify-between items-start mb-4">
                    <h3 class="text-slate-500 text-sm font-medium">Custo Total Produtos</h3>
                    <div class="p-2.5 border border-slate-100 rounded-xl bg-slate-50 text-slate-400">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
                    </div>
                </div>
                <div>
                    <p class="text-2xl font-semibold text-slate-800">R$ 18.230,00</p>
                </div>
            </div>

            <!-- KPI 3 -->
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 flex flex-col justify-between hover:shadow-md transition-shadow">
                <div class="flex justify-between items-start mb-4">
                    <h3 class="text-slate-500 text-sm font-medium">Total Taxas ML</h3>
                    <div class="p-2.5 border border-slate-100 rounded-xl bg-slate-50 text-slate-400">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                    </div>
                </div>
                <div>
                    <p class="text-2xl font-semibold text-slate-800">R$ 6.100,00</p>
                </div>
            </div>

            <!-- KPI 4 (Destaque) -->
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 flex flex-col justify-between relative overflow-hidden group">
                <!-- Highlight border effect -->
                <div class="absolute inset-0 border-2 border-emerald-500 rounded-2xl pointer-events-none"></div>
                <!-- Background decoration -->
                <div class="absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity">
                    <svg class="w-20 h-20 text-emerald-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
                </div>
                
                <div class="flex justify-between items-start mb-4 relative z-10">
                    <h3 class="text-slate-600 text-sm font-semibold">Lucro Líquido Total</h3>
                    <div class="p-2.5 border border-emerald-100 rounded-xl bg-emerald-50 text-emerald-600 shadow-sm">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                    </div>
                </div>
                <div class="relative z-10 flex flex-col mt-1">
                    <p class="text-3xl font-bold text-emerald-600">R$ 20.900,00</p>
                </div>
            </div>

            <!-- KPI 5 -->
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 flex flex-col justify-between hover:shadow-md transition-shadow">
                <div class="flex justify-between items-start mb-4">
                    <h3 class="text-slate-500 text-sm font-medium">Ticket Médio p/ Venda</h3>
                    <div class="p-2.5 border border-slate-100 rounded-xl bg-slate-50 text-slate-400">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path></svg>
                    </div>
                </div>
                <div>
                    <p class="text-2xl font-semibold text-slate-800">R$ 125,00</p>
                </div>
            </div>
        </div>

        <!-- Alertas e Destaques -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <!-- Card 1 (Sucesso) -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 border-l-4 border-l-emerald-500 p-4 flex items-start gap-4 hover:bg-slate-50 transition-colors">
                <div class="bg-emerald-100 text-emerald-600 p-2.5 rounded-full shrink-0">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                    </svg>
                </div>
                <div>
                    <h4 class="text-sm font-semibold text-slate-900">Produto mais lucrativo</h4>
                    <p class="text-xs text-slate-500 mt-0.5">Fone de Ouvido Bluetooth Premium</p>
                    <div class="mt-2">
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold bg-emerald-100 text-emerald-700">Margem: +45%</span>
                    </div>
                </div>
            </div>

            <!-- Card 2 (Perigo) -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 border-l-4 border-l-rose-500 p-4 flex items-start gap-4 hover:bg-slate-50 transition-colors">
                <div class="bg-rose-100 text-rose-600 p-2.5 rounded-full shrink-0">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                    </svg>
                </div>
                <div>
                    <h4 class="text-sm font-semibold text-slate-900">Margem Negativa</h4>
                    <p class="text-xs text-rose-600 font-medium mt-0.5">2 produtos vendidos abaixo do custo</p>
                    <button class="mt-2 text-xs font-medium text-slate-500 hover:text-slate-800 underline transition-colors cursor-pointer">Verificar produtos</button>
                </div>
            </div>

            <!-- Card 3 (Aviso) -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 border-l-4 border-l-amber-400 p-4 flex items-start gap-4 hover:bg-slate-50 transition-colors">
                <div class="bg-amber-100 text-amber-600 p-2.5 rounded-full shrink-0">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
                <div>
                    <h4 class="text-sm font-semibold text-slate-900">Sem NF-e / Custo</h4>
                    <p class="text-xs text-amber-700 font-medium mt-0.5">5 produtos com custo desconhecido</p>
                    <button class="mt-2 text-xs font-medium text-slate-500 hover:text-slate-800 underline transition-colors cursor-pointer">Atualizar custos</button>
                </div>
            </div>
        </div>

        <!-- Área do Gráfico -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 w-full">
            <h2 class="text-lg font-bold text-slate-900 mb-4">Evolução do Faturamento e Lucro Líquido</h2>
            <div class="min-h-[300px] w-full bg-slate-50 rounded-xl flex items-center justify-center border-2 border-dashed border-slate-300">
                <p class="text-slate-400 font-medium flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path></svg>
                    [ Área reservada para o Gráfico - Chart.js / ApexCharts ]
                </p>
            </div>
        </div>

        <!-- Tabela de Desempenho por Produto -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="p-5 border-b border-slate-100 flex flex-col sm:flex-row items-center justify-between gap-4">
                <h2 class="text-lg font-bold text-slate-900">Desempenho por Produto</h2>
                <!-- Search bar opcional mock -->
                <div class="relative w-full sm:w-72">
                    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    <input type="text" placeholder="Buscar produto..." class="w-full pl-9 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-colors">
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm whitespace-nowrap">
                    <thead class="bg-slate-50/80 text-slate-500 font-medium border-b border-slate-100">
                        <tr>
                            <th scope="col" class="px-6 py-4 cursor-pointer hover:text-slate-800 transition-colors group">
                                <div class="flex items-center gap-1">Produto</div>
                            </th>
                            <th scope="col" class="px-6 py-4 cursor-pointer hover:text-slate-800 transition-colors group">
                                <div class="flex items-center gap-1">Qtd. Vendida</div>
                            </th>
                            <th scope="col" class="px-6 py-4 cursor-pointer hover:text-slate-800 transition-colors group">
                                <div class="flex items-center gap-1">Receita Gerada</div>
                            </th>
                            <th scope="col" class="px-6 py-4 cursor-pointer hover:text-slate-800 transition-colors group">
                                <div class="flex items-center gap-1">Custo Total</div>
                            </th>
                            <th scope="col" class="px-6 py-4 cursor-pointer hover:text-slate-800 transition-colors group">
                                <div class="flex items-center gap-1">Taxas ML</div>
                            </th>
                            <th scope="col" class="px-6 py-4 cursor-pointer text-slate-900 font-semibold bg-slate-100/50">
                                <div class="flex items-center gap-1">
                                    Lucro Líquido
                                    <svg class="w-3.5 h-3.5 text-slate-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
                                </div>
                            </th>
                            <th scope="col" class="px-6 py-4 cursor-pointer hover:text-slate-800 transition-colors group">
                                <div class="flex items-center gap-1">Margem (%)</div>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        <!-- Linha 1 -->
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <img src="https://images.unsplash.com/photo-1612497843482-1dd239fe51df?ixlib=rb-1.2.1&auto=format&fit=crop&w=100&q=80" alt="Fone de Ouvido Bluetooth Premium" class="w-10 h-10 rounded-lg object-cover border border-slate-200">
                                    <div>
                                        <p class="font-medium text-slate-900">Fone de Ouvido Bluetooth Premium</p>
                                        <p class="text-xs text-slate-500 mt-0.5">SKU: FON-BT-01</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-slate-600">150</td>
                            <td class="px-6 py-4 font-semibold text-slate-800">R$ 15.000,00</td>
                            <td class="px-6 py-4 text-slate-600">R$ 5.000,00</td>
                            <td class="px-6 py-4 text-slate-600">R$ 3.250,00</td>
                            <td class="px-6 py-4 font-bold text-emerald-600 bg-slate-50/30">R$ 6.750,00</td>
                            <td class="px-6 py-4">
                                <span class="px-2.5 py-1 inline-flex items-center bg-emerald-100 text-emerald-700 rounded-md text-xs font-bold">
                                    +45%
                                </span>
                            </td>
                        </tr>

                        <!-- Linha 2 -->
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <!-- Placeholder thumbnail if no image -->
                                    <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center text-slate-400">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                    </div>
                                    <div>
                                        <p class="font-medium text-slate-900">Relógio Smartwatch Pro</p>
                                        <p class="text-xs text-slate-500 mt-0.5">SKU: REL-SW-PRO</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-slate-600">80</td>
                            <td class="px-6 py-4 font-semibold text-slate-800">R$ 8.000,00</td>
                            <td class="px-6 py-4 text-slate-600">R$ 4.000,00</td>
                            <td class="px-6 py-4 text-slate-600">R$ 1.600,00</td>
                            <td class="px-6 py-4 font-bold text-emerald-600 bg-slate-50/30">R$ 2.400,00</td>
                            <td class="px-6 py-4">
                                <span class="px-2.5 py-1 inline-flex items-center bg-emerald-100 text-emerald-700 rounded-md text-xs font-bold">
                                    +30%
                                </span>
                            </td>
                        </tr>

                        <!-- Linha 3 -->
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center text-slate-400">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                                    </div>
                                    <div>
                                        <p class="font-medium text-slate-900">Capa Anti-Impacto Celular</p>
                                        <p class="text-xs text-slate-500 mt-0.5">SKU: CAP-CEL-05</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-slate-600">200</td>
                            <td class="px-6 py-4 font-semibold text-slate-800">R$ 4.000,00</td>
                            <td class="px-6 py-4 text-slate-600">R$ 1.000,00</td>
                            <td class="px-6 py-4 text-slate-600">R$ 1.800,00</td>
                            <td class="px-6 py-4 font-bold text-emerald-600 bg-slate-50/30">R$ 1.200,00</td>
                            <td class="px-6 py-4">
                                <span class="px-2.5 py-1 inline-flex items-center bg-emerald-100 text-emerald-700 rounded-md text-xs font-bold">
                                    +30%
                                </span>
                            </td>
                        </tr>

                        <!-- Linha 4 (Margem Negativa) -->
                        <tr class="hover:bg-rose-50/50 transition-colors">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center text-slate-400">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                                    </div>
                                    <div>
                                        <p class="font-medium text-slate-900">Película de Vidro Temperado</p>
                                        <p class="text-xs text-slate-500 mt-0.5">SKU: PEL-VID-01</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-slate-600">50</td>
                            <td class="px-6 py-4 font-semibold text-slate-800">R$ 500,00</td>
                            <td class="px-6 py-4 text-slate-600">R$ 400,00</td>
                            <td class="px-6 py-4 text-slate-600">R$ 150,00</td>
                            <td class="px-6 py-4 font-bold text-rose-600 bg-rose-50/30">- R$ 50,00</td>
                            <td class="px-6 py-4">
                                <span class="px-2.5 py-1 inline-flex items-center bg-rose-100 text-rose-700 rounded-md text-xs font-bold">
                                    -10%
                                </span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            
            <!-- Footer da Tabela / Paginação -->
            <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between text-sm bg-slate-50/50">
                <span class="text-slate-500">Mostrando <span class="font-medium text-slate-900">4</span> de <span class="font-medium text-slate-900">128</span> produtos</span>
                <div class="flex items-center gap-2">
                    <button class="px-3 py-1.5 border border-slate-200 text-slate-400 bg-slate-50 rounded-lg cursor-not-allowed">Anterior</button>
                    <button class="px-3 py-1.5 border border-slate-900 bg-slate-900 text-white rounded-lg font-medium hover:bg-slate-800 transition-colors">1</button>
                    <button class="px-3 py-1.5 border border-slate-200 text-slate-600 bg-white rounded-lg font-medium hover:bg-slate-50 transition-colors">2</button>
                    <button class="px-3 py-1.5 border border-slate-200 text-slate-600 bg-white rounded-lg font-medium hover:bg-slate-50 transition-colors">3</button>
                    <span class="text-slate-400">...</span>
                    <button class="px-3 py-1.5 border border-slate-200 text-slate-600 bg-white rounded-lg hover:bg-slate-50 transition-colors">Próxima</button>
                </div>
            </div>
        </div>

    </div>
</body>
</html>
