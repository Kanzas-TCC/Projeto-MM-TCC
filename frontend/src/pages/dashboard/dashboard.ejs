<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MODAMYM — Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600;700&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="../../css/tailwind-compiled.css">
</head>

<body class="font-dm bg-[#F4F6F8] text-[#101828] flex min-h-screen">

  <!-- ══════════════════════════════════════
     SIDEBAR
══════════════════════════════════════ -->
  <aside class="w-60 bg-[#101828] min-h-screen fixed left-0 top-0 bottom-0 flex flex-col z-50">

    <!-- Logo -->
    <div class="px-6 pt-7 pb-6 border-b border-white/8 flex items-center gap-2.5">
      <div class="w-8 h-8 bg-[#00A63E] rounded-lg flex items-center justify-center shrink-0">
        <svg width="16" height="16" fill="white" viewBox="0 0 24 24">
          <path
            d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
        </svg>
      </div>
      <div>
        <div class="font-playfair text-[16px] font-bold text-white">MODAMYM</div>
        <div class="text-[9px] text-white/35 font-medium tracking-[1px] uppercase">Admin</div>
      </div>
    </div>

    <!-- Nav -->
    <nav class="flex-1 px-3 py-4 overflow-y-auto">

      <!-- Geral -->
      <div class="mb-6">
        <div class="text-[10px] font-bold text-white/30 tracking-[1.2px] uppercase px-3 mb-1.5">Geral</div>

        <a href="#" class="nav-item-active relative flex items-center gap-2.75 px-3 py-2.25 rounded-[9px] cursor-pointer
                               bg-[rgba(0,166,62,0.2)] text-[#4ade80] text-[13.5px] font-medium no-underline
                               transition-all duration-150">
          <svg class="w-4.25 h-4.25 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
            viewBox="0 0 24 24">
            <rect x="3" y="3" width="7" height="7" rx="1" />
            <rect x="14" y="3" width="7" height="7" rx="1" />
            <rect x="3" y="14" width="7" height="7" rx="1" />
            <rect x="14" y="14" width="7" height="7" rx="1" />
          </svg>
          Dashboard
        </a>

        <a href="#" class="relative flex items-center gap-2.75 px-3 py-2.25 rounded-[9px] cursor-pointer
                               text-white/55 text-[13.5px] font-medium no-underline
                               transition-all duration-150 hover:bg-white/[0.07] hover:text-white/90">
          <svg class="w-4.25 h-4.25 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
            viewBox="0 0 24 24">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
            <line x1="3" x2="21" y1="6" y2="6" />
            <path d="M16 10a4 4 0 0 1-8 0" />
          </svg>
          Pedidos
          <span class="ml-auto bg-[#00A63E] text-white rounded-full text-[10px] font-bold px-1.75 py-0.5">12</span>
        </a>

        <a href="#" class="relative flex items-center gap-2.75 px-3 py-2.25 rounded-[9px] cursor-pointer
                               text-white/55 text-[13.5px] font-medium no-underline
                               transition-all duration-150 hover:bg-white/[0.07] hover:text-white/90">
          <svg class="w-4.25 h-4.25 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
            viewBox="0 0 24 24">
            <path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z" />
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
          </svg>
          Produtos
        </a>

        <a href="#" class="relative flex items-center gap-2.75 px-3 py-2.25 rounded-[9px] cursor-pointer
                               text-white/55 text-[13.5px] font-medium no-underline
                               transition-all duration-150 hover:bg-white/[0.07] hover:text-white/90">
          <svg class="w-4.25 h-4.25 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
            viewBox="0 0 24 24">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
            <circle cx="12" cy="7" r="4" />
          </svg>
          Clientes
        </a>
      </div>

      <!-- Finanças -->
      <div class="mb-6">
        <div class="text-[10px] font-bold text-white/30 tracking-[1.2px] uppercase px-3 mb-1.5">Finanças</div>

        <a href="#" class="relative flex items-center gap-2.75 px-3 py-2.25 rounded-[9px] cursor-pointer
                               text-white/55 text-[13.5px] font-medium no-underline
                               transition-all duration-150 hover:bg-white/[0.07] hover:text-white/90">
          <svg class="w-4.25 h-4.25 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
            viewBox="0 0 24 24">
            <line x1="12" x2="12" y1="1" y2="23" />
            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
          </svg>
          Receita
        </a>

        <a href="#" class="relative flex items-center gap-2.75 px-3 py-2.25 rounded-[9px] cursor-pointer
                               text-white/55 text-[13.5px] font-medium no-underline
                               transition-all duration-150 hover:bg-white/[0.07] hover:text-white/90">
          <svg class="w-4.25 h-4.25 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
            viewBox="0 0 24 24">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
          </svg>
          Relatórios
        </a>

        <a href="#" class="relative flex items-center gap-2.75 px-3 py-2.25 rounded-[9px] cursor-pointer
                               text-white/55 text-[13.5px] font-medium no-underline
                               transition-all duration-150 hover:bg-white/[0.07] hover:text-white/90">
          <svg class="w-4.25 h-4.25 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
            viewBox="0 0 24 24">
            <rect x="2" y="3" width="20" height="14" rx="2" />
            <path d="M8 21h8M12 17v4" />
          </svg>
          Marketing
        </a>
      </div>

      <!-- Sistema -->
      <div class="mb-6">
        <div class="text-[10px] font-bold text-white/30 tracking-[1.2px] uppercase px-3 mb-1.5">Sistema</div>

        <a href="#" class="relative flex items-center gap-2.75 px-3 py-2.25 rounded-[9px] cursor-pointer
                               text-white/55 text-[13.5px] font-medium no-underline
                               transition-all duration-150 hover:bg-white/[0.07] hover:text-white/90">
          <svg class="w-4.25 h-4.25 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
            viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="3" />
            <path d="M19.07 4.93a10 10 0 0 1 1.414 14.143M4.93 4.93A10 10 0 0 0 3.515 19.07" />
          </svg>
          Configurações
        </a>

        <a href="modamym-store.html" class="relative flex items-center gap-2.75 px-3 py-2.25 rounded-[9px] cursor-pointer
                               text-white/55 text-[13.5px] font-medium no-underline
                               transition-all duration-150 hover:bg-white/[0.07] hover:text-white/90">
          <svg class="w-4.25 h-4.25 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
            viewBox="0 0 24 24">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            <polyline points="9 22 9 12 15 12 15 22" />
          </svg>
          Ver Loja
        </a>
      </div>
    </nav>

    <!-- User -->
    <div class="px-3 py-4 border-t border-white/8">
      <div
        class="flex items-center gap-2.5 px-3 py-2.5 rounded-[10px] cursor-pointer transition-colors duration-150 hover:bg-white/[0.07]">
        <div
          class="w-8.5 h-8.5 rounded-full bg-[linear-gradient(135deg,#00A63E,#059669)] flex items-center justify-center text-white text-[13px] font-bold shrink-0">
          A</div>
        <div>
          <div class="text-[12.5px] font-semibold text-white">Admin</div>
          <div class="text-[11px] text-white/40">Administrador</div>
        </div>
      </div>
    </div>
  </aside>

  <!-- ══════════════════════════════════════
     MAIN
══════════════════════════════════════ -->
  <div class="ml-60 flex-1 flex flex-col min-h-screen">

    <!-- Top Bar -->
    <header class="bg-white border-b border-[#E5E7EB] px-8 h-16 flex items-center justify-between sticky top-0 z-40">
      <div class="flex items-center gap-4">
        <span class="text-[17px] font-bold text-[#101828]">Dashboard</span>
        <span
          class="bg-[#F4F6F8] border border-[#E5E7EB] rounded-full px-3.5 py-1.75 text-[12.5px] text-[#6A7282] font-medium">
          17 de Março, 2026
        </span>
      </div>
      <div class="flex items-center gap-2">
        <!-- Search -->
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-[#99A1AF] pointer-events-none w-3.75 h-3.75"
            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.35-4.35" />
          </svg>
          <input type="text" placeholder="Buscar pedidos, clientes..." class="bg-[#F4F6F8] border-[1.5px] border-[#E5E7EB] rounded-full py-2 pl-9.5 pr-4 text-[13px] text-[#101828] outline-none w-65 font-dm
                           transition-colors duration-200 focus:border-[#00A63E]">
        </div>
        <!-- Notif -->
        <button
          class="relative w-9.5 h-9.5 rounded-[10px] border-[1.5px] border-[#E5E7EB] bg-white cursor-pointer flex items-center justify-center text-[#6A7282] transition-colors duration-200 hover:border-[#00A63E] hover:text-[#00A63E]">
          <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
            <path d="M13.73 21a2 2 0 0 1-3.46 0" />
          </svg>
          <span
            class="absolute top-1.5 right-1.5 w-1.75 h-1.75 bg-[#EF4444] rounded-full border-2 border-white"></span>
        </button>
        <!-- Settings -->
        <button
          class="w-9.5 h-9.5 rounded-[10px] border-[1.5px] border-[#E5E7EB] bg-white cursor-pointer flex items-center justify-center text-[#6A7282] transition-colors duration-200 hover:border-[#00A63E] hover:text-[#00A63E]">
          <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="3" />
            <path
              d="M19.07 4.93A10 10 0 0 1 21 12a10 10 0 0 1-1.93 5.07M4.93 4.93A10 10 0 0 0 3 12a10 10 0 0 0 1.93 5.07" />
          </svg>
        </button>
      </div>
    </header>

    <!-- Content -->
    <div class="p-8 flex-1">

      <!-- ── Stats Grid ── -->
      <div class="grid grid-cols-4 gap-4 mb-6">

        <!-- Receita -->
        <%- include('../components/stats-card.ejs', {
          icon: '<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" x2="12" y1="1" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg>'
          , percentage: '+18%' , value: 'R$48.290' , description: 'Receita este mês' }) %>

          <!-- Pedidos -->
          <%- include('../components/stats-card.ejs', {
            icon: '<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" /><line x1="3" x2="21" y1="6" y2="6" /></svg>'
            , percentage: '+7%' , value: '342' , description: 'Pedidos totais' }) %>

            <!-- Clientes -->
            <%- include('../components/stats-card.ejs', {
              icon: '<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>'
              , percentage: '+23%' , value: '1.847' , description: 'Clientes ativos' }) %>

              <!-- Ticket médio -->
              <%- include('../components/stats-card.ejs', {
                icon: '<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" /></svg>'
                , percentage: '-3%' , value: 'R$141' , description: 'Ticket médio' }) %>
      </div>

      <!-- ── Charts Row ── -->
      <div class="grid grid-cols-[1.6fr_1fr] gap-4 mb-6">

        <!-- Revenue Chart -->
        <div class="bg-white rounded-2xl border-[1.5px] border-[#E5E7EB] overflow-hidden">
          <div class="px-6 pt-5 pb-4 border-b border-[#E5E7EB] flex items-center justify-between">
            <div>
              <div class="text-[14.5px] font-bold text-[#101828]">Receita Mensal</div>
              <div class="text-[12px] text-[#6A7282] mt-0.5">Janeiro – Março 2026</div>
            </div>
            <button
              class="px-3 py-1.25 rounded-full text-[11px] font-semibold border border-[#E5E7EB] text-[#6A7282] cursor-pointer hover:border-[#00A63E] hover:text-[#00A63E] transition-colors duration-200">
              Este ano
            </button>
          </div>
          <div class="p-6">
            <!-- Bars -->
            <div class="flex items-end gap-2 h-45 px-1">
              <!-- Jan -->
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="flex-1 bg-[#F4F6F8] rounded-md w-full flex items-end overflow-hidden">
                  <div class="w-full rounded-md bg-[rgba(0,166,62,0.12)] transition-all duration-300"
                    style="height:60%"></div>
                </div>
                <span class="text-[10px] text-[#99A1AF] font-medium">Jan</span>
              </div>
              <!-- Fev -->
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="flex-1 bg-[#F4F6F8] rounded-md w-full flex items-end overflow-hidden">
                  <div class="w-full rounded-md bg-[rgba(0,166,62,0.12)] transition-all duration-300"
                    style="height:75%"></div>
                </div>
                <span class="text-[10px] text-[#99A1AF] font-medium">Fev</span>
              </div>
              <!-- Mar (active) -->
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="flex-1 bg-[#F4F6F8] rounded-md w-full flex items-end overflow-hidden">
                  <div
                    class="w-full rounded-md bg-[linear-gradient(180deg,#00A63E,#059669)] transition-all duration-300"
                    style="height:90%"></div>
                </div>
                <span class="text-[10px] text-[#99A1AF] font-medium">Mar</span>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="flex-1 bg-[#F4F6F8] rounded-md w-full flex items-end overflow-hidden">
                  <div class="w-full rounded-md bg-[rgba(0,166,62,0.12)]" style="height:45%"></div>
                </div>
                <span class="text-[10px] text-[#99A1AF] font-medium">Abr</span>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="flex-1 bg-[#F4F6F8] rounded-md w-full flex items-end overflow-hidden">
                  <div class="w-full rounded-md bg-[rgba(0,166,62,0.12)]" style="height:55%"></div>
                </div>
                <span class="text-[10px] text-[#99A1AF] font-medium">Mai</span>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="flex-1 bg-[#F4F6F8] rounded-md w-full flex items-end overflow-hidden">
                  <div class="w-full rounded-md bg-[rgba(0,166,62,0.12)]" style="height:68%"></div>
                </div>
                <span class="text-[10px] text-[#99A1AF] font-medium">Jun</span>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="flex-1 bg-[#F4F6F8] rounded-md w-full flex items-end overflow-hidden">
                  <div class="w-full rounded-md bg-[rgba(0,166,62,0.12)]" style="height:72%"></div>
                </div>
                <span class="text-[10px] text-[#99A1AF] font-medium">Jul</span>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="flex-1 bg-[#F4F6F8] rounded-md w-full flex items-end overflow-hidden">
                  <div class="w-full rounded-md bg-[rgba(0,166,62,0.12)]" style="height:80%"></div>
                </div>
                <span class="text-[10px] text-[#99A1AF] font-medium">Ago</span>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="flex-1 bg-[#F4F6F8] rounded-md w-full flex items-end overflow-hidden">
                  <div class="w-full rounded-md bg-[rgba(0,166,62,0.12)]" style="height:65%"></div>
                </div>
                <span class="text-[10px] text-[#99A1AF] font-medium">Set</span>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="flex-1 bg-[#F4F6F8] rounded-md w-full flex items-end overflow-hidden">
                  <div class="w-full rounded-md bg-[rgba(0,166,62,0.12)]" style="height:85%"></div>
                </div>
                <span class="text-[10px] text-[#99A1AF] font-medium">Out</span>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="flex-1 bg-[#F4F6F8] rounded-md w-full flex items-end overflow-hidden">
                  <div class="w-full rounded-md bg-[rgba(0,166,62,0.12)]" style="height:95%"></div>
                </div>
                <span class="text-[10px] text-[#99A1AF] font-medium">Nov</span>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="flex-1 bg-[#F4F6F8] rounded-md w-full flex items-end overflow-hidden">
                  <div class="w-full rounded-md bg-[rgba(0,166,62,0.12)]" style="height:100%"></div>
                </div>
                <span class="text-[10px] text-[#99A1AF] font-medium">Dez</span>
              </div>
            </div>

            <!-- Summary -->
            <div class="flex justify-between mt-5 pt-4 border-t border-[#E5E7EB]">
              <div class="text-center">
                <div class="text-[18px] font-bold text-[#101828]">R$48.290</div>
                <div class="text-[11px] text-[#6A7282]">Março (atual)</div>
              </div>
              <div class="text-center">
                <div class="text-[18px] font-bold text-[#101828]">R$39.840</div>
                <div class="text-[11px] text-[#6A7282]">Fevereiro</div>
              </div>
              <div class="text-center">
                <div class="text-[18px] font-bold text-[#101828]">R$32.100</div>
                <div class="text-[11px] text-[#6A7282]">Janeiro</div>
              </div>
              <div class="text-center">
                <div class="text-[18px] font-bold text-[#00A63E]">+18%</div>
                <div class="text-[11px] text-[#6A7282]">vs mês anterior</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Donut Chart -->
        <div class="bg-white rounded-2xl border-[1.5px] border-[#E5E7EB] overflow-hidden">
          <div class="px-6 pt-5 pb-4 border-b border-[#E5E7EB]">
            <div class="text-[14.5px] font-bold text-[#101828]">Vendas por Categoria</div>
            <div class="text-[12px] text-[#6A7282] mt-0.5">Distribuição atual</div>
          </div>
          <div class="p-6">
            <div class="flex items-center gap-6">
              <svg class="shrink-0" width="140" height="140" viewBox="0 0 140 140">
                <circle cx="70" cy="70" r="50" fill="none" stroke="#F4F6F8" stroke-width="22" />
                <circle cx="70" cy="70" r="50" fill="none" stroke="#00A63E" stroke-width="22"
                  stroke-dasharray="131.9 314.16" stroke-dashoffset="0" stroke-linecap="butt"
                  transform="rotate(-90 70 70)" />
                <circle cx="70" cy="70" r="50" fill="none" stroke="#3B82F6" stroke-width="22"
                  stroke-dasharray="87.96 314.16" stroke-dashoffset="-131.9" stroke-linecap="butt"
                  transform="rotate(-90 70 70)" />
                <circle cx="70" cy="70" r="50" fill="none" stroke="#F59E0B" stroke-width="22"
                  stroke-dasharray="56.55 314.16" stroke-dashoffset="-219.86" stroke-linecap="butt"
                  transform="rotate(-90 70 70)" />
                <circle cx="70" cy="70" r="50" fill="none" stroke="#E5E7EB" stroke-width="22"
                  stroke-dasharray="37.7 314.16" stroke-dashoffset="-276.41" stroke-linecap="butt"
                  transform="rotate(-90 70 70)" />
                <text x="70" y="65" text-anchor="middle" font-size="20" font-weight="700" fill="#101828"
                  font-family="DM Sans,sans-serif">42%</text>
                <text x="70" y="82" text-anchor="middle" font-size="10" fill="#99A1AF"
                  font-family="DM Sans,sans-serif">Calçados</text>
              </svg>
              <div class="flex flex-col gap-2.5">
                <div class="flex items-center gap-2.5">
                  <div class="w-2.5 h-2.5 rounded-[3px] shrink-0 bg-[#00A63E]"></div>
                  <span class="text-[12.5px] text-[#6A7282]">Calçados</span>
                  <span class="text-[13px] font-bold text-[#101828] ml-auto">42%</span>
                </div>
                <div class="flex items-center gap-2.5">
                  <div class="w-2.5 h-2.5 rounded-[3px] shrink-0 bg-[#3B82F6]"></div>
                  <span class="text-[12.5px] text-[#6A7282]">Jaquetas</span>
                  <span class="text-[13px] font-bold text-[#101828] ml-auto">28%</span>
                </div>
                <div class="flex items-center gap-2.5">
                  <div class="w-2.5 h-2.5 rounded-[3px] shrink-0 bg-[#F59E0B]"></div>
                  <span class="text-[12.5px] text-[#6A7282]">Botas</span>
                  <span class="text-[13px] font-bold text-[#101828] ml-auto">18%</span>
                </div>
